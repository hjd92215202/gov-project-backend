# =========================
# gov-project-backend 环境变量示例
# =========================

# 国密 SM4 密钥（16位）
GOV_SM4_KEY=1234567812345678
GOV_SM4_ENABLED=true
GOV_SM4_ALLOW_PLAINTEXT_FALLBACK=true

# 密码摘要额外因子（pepper）
GOV_PASSWORD_PEPPER=

# 日志路径（默认 ./logs）
LOG_PATH=./logs

# 后端脚本默认使用的 JDK 路径
GOV_JAVA_HOME=C:\Program Files\Java\jdk1.8.0_112

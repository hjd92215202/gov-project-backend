<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="Examples">

    <process id="projectApproval" name="工程项目多级动态审批" isExecutable="true">

        <startEvent id="startNode" name="发起申请" />

        <!-- 核心审批节点：处理人由变量 ${currentAssignee} 决定 -->
        <userTask id="approveTask" name="逐级审批" flowable:assignee="${currentAssignee}" />

        <!-- 判断：同意还是驳回 -->
        <exclusiveGateway id="judgeGateway" name="审核结果" />

        <!-- 判断：是否还有下一级上级 -->
        <exclusiveGateway id="checkNextGateway" name="是否有下一级" />

        <endEvent id="endNode" name="审批通过" />
        <endEvent id="rejectEnd" name="审批驳回" />

        <!-- 连线逻辑 -->
        <sequenceFlow sourceRef="startNode" targetRef="approveTask" />
        <sequenceFlow sourceRef="approveTask" targetRef="judgeGateway" />

        <!-- 驳回：直接连到结束，状态设为驳回 -->
        <sequenceFlow sourceRef="judgeGateway" targetRef="rejectEnd">
            <conditionExpression>${approved == false}</conditionExpression>
        </sequenceFlow>

        <!-- 同意：进入“是否有下一级”的判断 -->
        <sequenceFlow sourceRef="judgeGateway" targetRef="checkNextGateway">
            <conditionExpression>${approved == true}</conditionExpression>
        </sequenceFlow>

        <!-- 有下一级：回到 approveTask 节点，由 Java 设置新的 currentAssignee -->
        <sequenceFlow sourceRef="checkNextGateway" targetRef="approveTask">
            <conditionExpression>${hasNext == true}</conditionExpression>
        </sequenceFlow>

        <!-- 没有下一级了：终审通过 -->
        <sequenceFlow sourceRef="checkNextGateway" targetRef="endNode">
            <conditionExpression>${hasNext == false}</conditionExpression>
        </sequenceFlow>

    </process>
</definitions>
<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="Examples">

    <!-- 定义流程 ID 为 projectApproval -->
    <process id="projectApproval" name="工程项目审批流程" isExecutable="true">

        <!-- 1. 开始节点 -->
        <startEvent id="startNode" name="发起申请" />

        <!-- 2. 部门负责人审批节点 -->
        <userTask id="deptLeaderTask" name="部门负责人审批" flowable:assignee="${deptLeaderId}" />

        <!-- 3. 上级领导审批节点 -->
        <userTask id="topLeaderTask" name="上级领导审批" flowable:assignee="${topLeaderId}" />

        <!-- 4. 结束节点 -->
        <endEvent id="endNode" name="审批通过" />

        <!-- 连线：开始 -> 部门负责人 -->
        <sequenceFlow sourceRef="startNode" targetRef="deptLeaderTask" />

        <!-- 连线：部门负责人 -> 上级领导 (条件：approve == true) -->
        <sequenceFlow sourceRef="deptLeaderTask" targetRef="topLeaderTask">
            <conditionExpression xsi:type="tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                ${approved == true}
            </conditionExpression>
        </sequenceFlow>

        <!-- 连线：部门负责人 -> 结束 (条件：approved == false，实际业务中可连回发起者，这里演示直接结束并置为驳回状态) -->
        <sequenceFlow sourceRef="deptLeaderTask" targetRef="startNode">
            <conditionExpression xsi:type="tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
                ${approved == false}
            </conditionExpression>
        </sequenceFlow>

        <!-- 连线：上级领导 -> 结束 -->
        <sequenceFlow sourceRef="topLeaderTask" targetRef="endNode" />

    </process>
</definitions>